# Copy this file to .env for local dev. On Render, set these as real
# environment variables in the dashboard instead — do not commit .env.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

DEFAULT_UNIVERSITY_CODE=USTED

# Capacitor apps typically load from capacitor://localhost (iOS) or
# http://localhost (Android). Add your web frontend's domain too once
# it has one. Comma-separated, or "*" while everything's still local.
CORS_ORIGINS=*

FLASK_ENV=production
